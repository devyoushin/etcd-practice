{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(etcdctl get*)",
      "Bash(etcdctl endpoint*)",
      "Bash(etcdctl member*)",
      "Bash(etcdctl alarm*)",
      "Bash(etcdctl snapshot status*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(docker compose ps*)"
    ],
    "deny": [
      "Bash(etcdctl del*)",
      "Bash(etcdctl member remove*)",
      "Bash(docker rm*)",
      "Bash(docker compose down*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo $CLAUDE_TOOL_INPUT | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('file_path',''))\" 2>/dev/null); [ -n \"$file\" ] && echo \"[etcd-practice] 저장: $(basename $file)\""
          }
        ]
      }
    ]
  }
}
